<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:LightStudio.LightPlayer.ViewModels.Dialogs"
        xmlns:runtime="using:LightStudio.MediaLibraryCore.Lyrics.RuntimeApi"
        mc:Ignorable="d"
        d:DesignWidth="400"
        d:DesignHeight="540"
        x:Class="LightStudio.LightPlayer.Views.Dialogs.LyricSearchDialog"
        x:DataType="vm:LyricSearchDialogViewModel"
        Width="400"
        Height="560"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Title="Search lyrics">
    <DockPanel Margin="18" LastChildFill="True">
        <TextBlock DockPanel.Dock="Top"
                   Text="Choose lyrics from catalog"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" Margin="0,0,0,8">
            <TextBox Grid.Row="0" Grid.Column="0"
                     PlaceholderText="Title"
                     Text="{Binding Title, Mode=TwoWay}">
                <TextBox.KeyBindings>
                    <KeyBinding Gesture="Enter" Command="{Binding SearchCommand}" />
                </TextBox.KeyBindings>
            </TextBox>
            <TextBox Grid.Row="1" Grid.Column="0"
                     Margin="0,6,0,0"
                     PlaceholderText="Artist"
                     Text="{Binding Artist, Mode=TwoWay}">
                <TextBox.KeyBindings>
                    <KeyBinding Gesture="Enter" Command="{Binding SearchCommand}" />
                </TextBox.KeyBindings>
            </TextBox>
            <Button Grid.Row="0" Grid.Column="1"
                    Grid.RowSpan="2"
                    Classes="icon"
                    Margin="6,0,0,0"
                    VerticalAlignment="Stretch"
                    Command="{Binding SearchCommand}"
                    ToolTip.Tip="Search">
                <Viewbox Width="18" Height="18">
                    <Path Data="{StaticResource IconSearch}" Fill="{DynamicResource AppPrimaryTextBrush}" />
                </Viewbox>
            </Button>
        </Grid>

        <ProgressBar DockPanel.Dock="Top"
                     Margin="0,2,0,8"
                     Height="4"
                     IsIndeterminate="True"
                     IsVisible="{Binding IsBusy}" />

        <TextBlock DockPanel.Dock="Top"
                   Margin="0,0,0,8"
                   Text="{Binding ResultText}"
                   Foreground="{DynamicResource AppSecondaryTextBrush}"
                   IsVisible="{Binding !IsBusy}" />

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,12,0,0">
            <Button x:Name="CancelButton" Content="Cancel" />
            <Button x:Name="SelectButton" Content="Select" IsDefault="True" IsEnabled="{Binding CanSelect}" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    Spacing="12"
                    Margin="0,10,0,0">
            <Button x:Name="ImportButton"
                    Classes="link"
                    Content="Import external lyrics..." />
            <Button x:Name="ClearButton"
                    Classes="link"
                    Content="Clear lyrics" />
        </StackPanel>

        <ListBox x:Name="CandidateList"
                 ItemsSource="{Binding Candidates}"
                 SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="runtime:ExternalLrcInfo">
                    <StackPanel Spacing="2" Margin="2">
                        <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Artist}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource AppSecondaryTextBrush}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
