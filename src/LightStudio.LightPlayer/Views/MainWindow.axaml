<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LightStudio.LightPlayer.ViewModels"
    xmlns:views="using:LightStudio.LightPlayer.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="720"
        x:Class="LightStudio.LightPlayer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/light-logo.ico"
    Title="{Binding Shell.CurrentPage.Title, StringFormat='{}{0} — Light'}"
    Width="1100"
    Height="720"
    MinWidth="800"
    MinHeight="600">

    <views:ShellView DataContext="{Binding Shell}" />

</Window>
