<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:LightStudio.LightPlayer.Controls"
             xmlns:models="using:LightStudio.LightPlayer.Models"
             xmlns:vm="using:LightStudio.LightPlayer.ViewModels.Pages"
             mc:Ignorable="d"
             d:DesignWidth="900"
             d:DesignHeight="640"
             x:Class="LightStudio.LightPlayer.Views.Pages.PlaylistDetailPageView"
             x:DataType="vm:PlaylistDetailPageViewModel">
    <DockPanel>
        <!-- Header -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*" Margin="20,32">
            <Border Grid.Column="0"
                    Width="120"
                    Height="120"
                    CornerRadius="6"
                    Background="{DynamicResource AppNavBackgroundBrush}">
                <Viewbox Width="56" Height="56">
                    <Path Data="{StaticResource IconPlaylist}"
                          Fill="{DynamicResource AppSecondaryTextBrush}" />
                </Viewbox>
            </Border>

            <DockPanel Grid.Column="1" Margin="20,0,0,0">
                <StackPanel VerticalAlignment="Bottom" Spacing="6">
                    <!-- Back button sits to the left of the title, between it and the
                         playlist icon. Its Auto column collapses to zero width when the
                         button is hidden, keeping the title flush against the icon. -->
                    <Grid ColumnDefinitions="Auto,*">
                        <Button Grid.Column="0"
                                Classes="icon"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0"
                                IsVisible="{Binding ShowBackButton}"
                                Command="{Binding BackCommand}"
                                ToolTip.Tip="Back">
                            <Viewbox Width="20" Height="20">
                                <Path Data="{StaticResource IconArrowLeft}"
                                      Fill="{DynamicResource AppPrimaryTextBrush}" />
                            </Viewbox>
                        </Button>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Title}"
                                   FontSize="26"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   MaxLines="2"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppPrimaryTextBrush}" />
                    </Grid>
                    <TextBlock Text="{Binding HeaderSubtitle}"
                               FontSize="13"
                               Foreground="{DynamicResource AppSecondaryTextBrush}" />

                    <StackPanel Orientation="Horizontal" Spacing="2" Margin="0,10,0,0">
                        <Button Classes="icon" Command="{Binding PlayCommand}" ToolTip.Tip="Play">
                            <Viewbox Width="18" Height="18">
                                <Path Data="{StaticResource IconPlay}" Fill="{DynamicResource AppPrimaryTextBrush}" />
                            </Viewbox>
                        </Button>
                        <Button Classes="icon" Command="{Binding ShuffleCommand}" ToolTip.Tip="Shuffle">
                            <Viewbox Width="18" Height="18">
                                <Path Data="{StaticResource IconShuffleAll}" Fill="{DynamicResource AppPrimaryTextBrush}" />
                            </Viewbox>
                        </Button>
                        <Button Classes="icon" Command="{Binding AddToQueueCommand}" ToolTip.Tip="Add to queue">
                            <Viewbox Width="18" Height="18">
                                <Path Data="{StaticResource IconAdd}" Fill="{DynamicResource AppPrimaryTextBrush}" />
                            </Viewbox>
                        </Button>
                        <Button Classes="icon" ToolTip.Tip="More">
                            <Viewbox Width="18" Height="18">
                                <Path Data="{StaticResource IconMore}" Fill="{DynamicResource AppPrimaryTextBrush}" />
                            </Viewbox>
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuItem Header="Rename" Command="{Binding RenameCommand}" />
                                    <MenuItem Header="Export..." Command="{Binding ExportCommand}" />
                                    <Separator />
                                    <MenuItem Header="Delete playlist" Command="{Binding DeleteCommand}" />
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Grid>

        <!-- Items / empty state -->
        <Panel>
            <ScrollViewer IsVisible="{Binding ShowContent}" Margin="10,0,10,0">
                <ItemsControl ItemsSource="{Binding Rows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:TrackRowModel">
                            <controls:TrackRow />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <controls:EmptyState IsVisible="{Binding ShowEmpty}"
                                 Header="{Binding EmptyHeader}"
                                 Description="{Binding EmptyDescription}" />
        </Panel>
    </DockPanel>
</UserControl>
