<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="using:LightStudio.LightPlayer.Models"
             mc:Ignorable="d"
             d:DesignWidth="380"
             d:DesignHeight="480"
             x:Name="Root"
             x:Class="LightStudio.LightPlayer.Controls.LyricsPresenter">
    <UserControl.Styles>
        <Style Selector="TextBlock.lyric">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Opacity" Value="0.55" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,6" />
            <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}" />
        </Style>
        <Style Selector="TextBlock.lyric.current">
            <Setter Property="FontSize" Value="19" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
        </Style>
    </UserControl.Styles>
    <ScrollViewer x:Name="Scroll" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
        <ItemsControl x:Name="Lines" Margin="24,12">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:LyricLineModel">
                    <TextBlock Classes="lyric"
                               Classes.current="{Binding IsCurrent}"
                               Text="{Binding Text}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
