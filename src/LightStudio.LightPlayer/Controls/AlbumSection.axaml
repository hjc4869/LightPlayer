<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:LightStudio.LightPlayer.Controls"
             xmlns:models="using:LightStudio.LightPlayer.Models"
             mc:Ignorable="d"
             d:DesignWidth="820"
             d:DesignHeight="320"
             x:Class="LightStudio.LightPlayer.Controls.AlbumSection"
             x:DataType="models:ArtistAlbumSectionModel">
    <!-- Album block: cover + year on the left (hidden when narrow), album title with
         play/queue actions on top-right, and the album's track rows below. -->
    <Grid ColumnDefinitions="Auto,*">
        <StackPanel x:Name="CoverPanel"
                    Grid.Column="0"
                    Width="200"
                    Margin="0,0,14,0"
                    Spacing="10">
            <controls:MediaThumbnail Width="200"
                                     Height="200"
                                     CornerRadius="6"
                                     Source="{Binding CoverImage}"
                                     PlaceholderKind="Album" />
            <TextBlock Text="{Binding Year}"
                       IsVisible="{Binding HasYear}"
                       FontSize="13"
                       Foreground="{DynamicResource AppSecondaryTextBrush}" />
        </StackPanel>

        <Grid Grid.Column="1" RowDefinitions="Auto,*">
            <DockPanel Grid.Row="0" Margin="0,4,0,8">
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            Spacing="2"
                            VerticalAlignment="Center">
                    <Button Classes="icon"
                            Command="{Binding AddToQueueCommand}"
                            ToolTip.Tip="Add to queue">
                        <Viewbox Width="18" Height="18">
                            <Path Data="{StaticResource IconAdd}"
                                  Fill="{DynamicResource AppPrimaryTextBrush}" />
                        </Viewbox>
                    </Button>
                    <Button Classes="icon"
                            Command="{Binding PlayCommand}"
                            ToolTip.Tip="Play">
                        <Viewbox Width="18" Height="18">
                            <Path Data="{StaticResource IconPlay}"
                                  Fill="{DynamicResource AppPrimaryTextBrush}" />
                        </Viewbox>
                    </Button>
                </StackPanel>
                <TextBlock Margin="26,0,0,0"
                           Text="{Binding Title}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           MaxLines="1"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource AppPrimaryTextBrush}" />
            </DockPanel>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding Tracks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:TrackRowModel">
                        <controls:TrackRow />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</UserControl>
