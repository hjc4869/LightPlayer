  <name>Light Player</name>
  <summary>Play and organize your local music library</summary>

  <description>
    <p>
      Light Player is a cross-platform desktop music player. Scan your local
      folders into a browsable library of songs, albums, and artists, build
      playlists, and enjoy gapless playback with lyrics and cover art.
    </p>
    <p>Features:</p>
    <ul>
      <li>Browse your library by song, album, and artist</li>
      <li>Create and manage playlists</li>
      <li>Search across your collection</li>
      <li>Media-key and "now playing" integration (MPRIS)</li>
      <li>Open audio files directly to replace the current queue</li>
    </ul>
  </description>

  <launchable type="desktop-id">im.hjc.LightPlayer.desktop</launchable>

